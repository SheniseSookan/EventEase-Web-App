@model EventEase.Models.Event

@{
    ViewData["Title"] = "Create Event";
}

<h1>Create New Event</h1>

<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div class="form-group mb-2">
                <label asp-for="EventName" class="control-label">Event Name</label>
                <input asp-for="EventName" class="form-control" />
            </div>
            <div class="form-group mb-2">
                <label asp-for="Description" class="control-label">Description</label>
                <input asp-for="Description" class="form-control" />
            </div>
            <div class="form-group mb-2">
                <label asp-for="EventDate" class="control-label">Event Date</label>
                <input asp-for="EventDate" class="form-control" type="date" />
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="ImageUrl" class="control-label">Image URL</label>
                <input asp-for="ImageUrl" class="form-control" placeholder="https://via.placeholder.com/150" />
            </div>

            <div class="form-group">
                <input type="submit" value="Save Event" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>