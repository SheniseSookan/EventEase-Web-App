@model EventEase.Models.Booking

@{
    ViewData["Title"] = "Create New Booking";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-muted">Bookings</a></li>
                    <li class="breadcrumb-item active fw-bold text-primary" aria-current="page">New Reservation</li>
                </ol>
            </nav>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div style="height: 6px; background: linear-gradient(to right, #6366f1, #f43f5e);"></div>
                
                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4">
                        <div class="mb-2">
                            <i class="bi bi-calendar2-check text-primary" style="font-size: 3rem;"></i>
                        </div>
                        <h2 class="fw-bold">Reserve Your Event</h2>
                        <p class="text-muted">Enter the details below to secure your date.</p>
                    </div>

                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 shadow-sm rounded-3 py-2 small" role="alert"></div>

                        <div class="mb-4">
                            <label class="form-label fw-bold small text-uppercase text-muted ls-1">Customer Information</label>
                            
                            <div class="form-floating mb-3">
                                <input asp-for="CustomerName" class="form-control border-0 bg-light" placeholder="Full Name" />
                                <label asp-for="CustomerName"><i class="bi bi-person me-2"></i>Full Name</label>
                                <span asp-validation-for="CustomerName" class="text-danger small"></span>
                            </div>

                            <div class="form-floating mb-3">
                                <input asp-for="CustomerEmail" class="form-control border-0 bg-light" placeholder="Email Address" />
                                <label asp-for="CustomerEmail"><i class="bi bi-envelope me-2"></i>Email Address</label>
                                <span asp-validation-for="CustomerEmail" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold small text-uppercase text-muted ls-1">Event Logistics</label>
                            
                            <div class="form-floating mb-3">
                                <input asp-for="BookingDate" type="date" class="form-control border-0 bg-light" />
                                <label asp-for="BookingDate"><i class="bi bi-calendar-event me-2"></i>Event Date</label>
                                <span asp-validation-for="BookingDate" class="text-danger small"></span>
                            </div>

                            <div class="row g-2">
                                <div class="col-md-6 mb-3">
                                    <label class="small text-muted mb-1 ms-1">Event Type</label>
                                    <select asp-for="EventId" class="form-select border-0 bg-light py-3" asp-items="ViewBag.EventId">
                                        <option value="">-- Select Event --</option>
                                    </select>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="small text-muted mb-1 ms-1">Venue Location</label>
                                    <select asp-for="VenueId" class="form-select border-0 bg-light py-3" asp-items="ViewBag.VenueId">
                                        <option value="">-- Select Venue --</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid gap-2 pt-3">
                            <button type="submit" class="btn btn-primary btn-lg shadow fw-bold">
                                <i class="bi bi-check-circle-fill me-2"></i> Confirm Booking
                            </button>
                            <a asp-action="Index" class="btn btn-link text-muted">Cancel and Go Back</a>
                        </div>
                    </form>
                </div>
            </div>
            
            <p class="text-center mt-4 text-muted small">
                <i class="bi bi-shield-lock-fill"></i> Secure EventEase Reservation System
            </p>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}