@model IEnumerable<EventEase.Models.Booking>

@{
    ViewData["Title"] = "All Bookings";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold text-primary">All Bookings</h1>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="bi bi-calendar-plus"></i> Make a New Booking
        </a>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body bg-light">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-8">
                    <input type="text" name="searchString" class="form-control"
                           placeholder="Search by Booking ID or Event Name..."
                           value="@ViewData["CurrentFilter"]" />
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-dark w-100">Search</button>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle bg-white">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Customer</th>
                    <th>Event</th>
                    <th>Venue</th>
                    <th>Date</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">#@item.BookingId</td>
                        <td>
                            <div class="fw-bold">@item.CustomerName</div>
                            <small class="text-muted">@item.CustomerEmail</small>
                        </td>
                        @* These display the names from the related tables *@
                        <td>@(item.Event?.EventName ?? "N/A")</td>
                        <td>@(item.Venue?.Name ?? "N/A")</td>
                        <td>@item.BookingDate.ToShortDateString()</td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@item.BookingId" class="btn btn-sm btn-outline-info">View</a>
                            <a asp-action="Delete" asp-route-id="@item.BookingId" class="btn btn-sm btn-outline-danger">Cancel</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>