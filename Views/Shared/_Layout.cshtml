<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EventEase</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Poppins:wght@300;400;600&family=Dancing+Script:wght@700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <style>
        /* 1. KEYFRAMES FIRST (Fixes parser errors) */
        @@keyframes float {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
            100% { transform: translateY(0px); }
        }

        :root {
            --candy-pink: #ffdae9;
            --strawberry: #ff85a1;
            --lavender: #f3e8ff;
            --mint: #e0f9f1;
            --cream: #fff9fb;
            --text-plum: #5a4a5e;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, var(--cream) 0%, #fdf2f8 100%);
            color: var(--text-plum);
            min-height: 100vh;
        }

        h1, h2, h3, .brand-name {
            font-family: 'Playfair Display', serif;
            font-weight: 700;
            background: linear-gradient(45deg, var(--text-plum), var(--strawberry));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .fancy-accent {
            font-family: 'Dancing Script', cursive;
            color: var(--strawberry);
            font-size: 1.5rem;
        }

        .hero-container {
            animation: float 6s ease-in-out infinite;
            border: 12px solid white !important;
            box-shadow: 0 25px 50px -12px rgba(255, 133, 161, 0.25) !important;
        }

        .custom-nav {
            background: rgba(255, 255, 255, 0.6) !important;
            backdrop-filter: blur(20px);
            padding: 1rem 0;
            border-bottom: 2px solid var(--candy-pink) !important;
        }

        .logo-circle {
            background: linear-gradient(135deg, var(--strawberry), #ffb3c6);
            color: white;
            width: 45px;
            height: 45px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50% 15% 50% 15%;
            box-shadow: 0 8px 15px rgba(255, 133, 161, 0.2);
        }

        .nav-link {
            font-weight: 600;
            color: var(--text-plum) !important;
        }

        .btn-primary {
            background: linear-gradient(45deg, var(--strawberry), #ff9eb5);
            border: 3px solid white;
            border-radius: 50px;
            padding: 12px 30px;
            font-weight: 600;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .btn-primary:hover {
            transform: scale(1.1) rotate(-2deg);
        }

        .card {
            border: none !important;
            border-radius: 30px !important;
            transition: all 0.5s ease !important;
        }

        footer {
            background: rgba(255, 255, 255, 0.5);
            padding: 4rem 0;
            margin-top: 5rem;
            border-radius: 50% 50% 0 0 / 20% 20% 0 0;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light custom-nav mb-5">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <div class="logo-circle">EE</div>
                    <span class="brand-name">EventEase</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Venues" asp-action="Index">Venues</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Bookings" asp-action="Index">Bookings</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="text-center">
        <div class="container">
            <span class="fancy-accent">Stay Sweet!</span>
            <p class="mt-2 mb-0 fw-bold">EventEase &copy; 2026</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>