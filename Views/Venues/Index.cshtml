@model IEnumerable<EventEase.Models.Venue>

@{
    ViewData["Title"] = "Venues";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold text-primary">Venues</h1>
        <a asp-action="Create" class="btn btn-primary shadow-sm px-4">
            <i class="bi bi-plus-circle"></i> + Add New Venue
        </a>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <form asp-action="Index" method="get">
                <div class="input-group shadow-sm">
                    <input type="text" name="searchString" class="form-control" placeholder="Search by Venue Name..." value="@ViewData["CurrentFilter"]" />
                    <button type="submit" class="btn btn-dark">Search</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <div class="row">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <p class="text-muted">No venues found matching your search.</p>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow border-0 overflow-hidden">
                        <img src="@item.ImageUrl" class="card-img-top" alt="@item.Name"
                             style="height: 200px; object-fit: cover;"
                             onerror="this.src='https://via.placeholder.com/400x200?text=No+Image+Available';">
                        
                        <div class="card-body">
                            <h5 class="card-title fw-bold">@item.Name</h5>
                            <p class="card-text text-muted mb-2">
                                <i class="bi bi-geo-alt"></i> @item.Location
                            </p>
                            <span class="badge rounded-pill bg-success px-3">Capacity: @item.Capacity</span>
                        </div>

                        <div class="card-footer bg-white border-0 d-flex gap-2 pb-3">
                            <a asp-action="Edit" asp-route-id="@item.VenueId" class="btn btn-sm btn-outline-secondary w-50">Edit</a>
                            
                            <form asp-action="Delete" asp-route-id="@item.VenueId" method="post" class="w-50" onsubmit="return confirm('Are you sure you want to delete this venue?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger w-100">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>