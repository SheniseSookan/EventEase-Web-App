@model EventEase.Models.Venue

@{
    ViewData["Title"] = "Create Venue";
}

<h1>Create Venue</h1>

<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div class="form-group mb-2">
                <label asp-for="Name" class="control-label">Venue Name</label>
                <input asp-for="Name" class="form-control" />
            </div>
            <div class="form-group mb-2">
                <label asp-for="Location" class="control-label">Location</label>
                <input asp-for="Location" class="form-control" />
            </div>
            <div class="form-group mb-2">
                <label asp-for="Capacity" class="control-label">Capacity</label>
                <input asp-for="Capacity" class="form-control" />
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="ImageUrl" class="control-label">Image URL</label>
                <input asp-for="ImageUrl" class="form-control" placeholder="https://via.placeholder.com/150" />
            </div>

            <div class="form-group">
                <input type="submit" value="Save Venue" class="btn btn-success" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>